    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/client-sqs": "^3.1053.0",
    "aws-cdk-lib": "^2.257.0",
    "constructs": "^10.4.2",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.13.1",
    "aws-cdk": "^2.257.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
