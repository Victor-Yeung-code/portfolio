{
  "name": "victor-portfolio-infra",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc --noEmit",
    "cdk": "node ./node_modules/aws-cdk/bin/cdk",
