---
import { GalleryNav } from '../components/public/GalleryNav';
import { SiteFooter } from '../components/public/SiteFooter';
import '../styles/public.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Victor Yeung',
  description = 'Art and photography portfolio by Victor Yeung.'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_ID;
const isAdminPage = Astro.url.pathname.startsWith('/admin');
const loadGA = gaId && !isAdminPage;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Victor Yeung" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {
      loadGA && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
  </head>
  <body class={isAdminPage ? 'admin-page' : 'public-page'}>
    {
      !isAdminPage && (
        <header class="site-header">
          <a class="brand" href="/" aria-label="Victor Yeung home">
            Victor Yeung
          </a>
          <nav aria-label="Primary navigation">
            <GalleryNav currentPath={currentPath} client:load />
            <a class={currentPath === '/about' ? 'is-active' : ''} href="/about">About</a>
            <a class={currentPath === '/contact' ? 'is-active' : ''} href="/contact">Contact</a>
          </nav>
        </header>
      )
    }
    <slot />
    {
      !isAdminPage && (
        <footer class="site-footer">
          <SiteFooter client:load />
        </footer>
      )
    }
  </body>
</html>
