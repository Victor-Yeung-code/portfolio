---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Victor Yeung" description="The requested Victor Yeung portfolio page could not be found.">
  <main class="not-found">
    <a href="/" aria-label="Back to home">Victor Yeung</a>
    <h1>Page not found</h1>
  </main>
</BaseLayout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #faf8f3;
    color: #111;
  }

  .not-found {
    display: grid;
    min-height: 100vh;
    place-content: center;
    gap: 1rem;
    padding: 2rem;
    text-align: center;
  }

  a {
    color: inherit;
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    text-decoration: none;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: 0;
  }
</style>
