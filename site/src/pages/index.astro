---
import { PublicGallery } from '../components/public/PublicGallery';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Victor Yeung | Photography Portfolio"
  description="Art and photography portfolio by Victor Yeung."
>
  <main class="public-main">
    <section class="gallery-hero" aria-labelledby="page-title">
      <div>
        <p class="eyebrow">Art / Photography</p>
        <h1 id="page-title">Victor Yeung</h1>
      </div>
      <p>A curated photography gallery with downloadable full-size works.</p>
    </section>

    <PublicGallery client:load />
  </main>
</BaseLayout>
